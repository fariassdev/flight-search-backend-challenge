{
  "name": "flight-search-api",
  "version": "1.0.0",
  "description": "Flight search API coding challenge",
  "main": "dist/server.js",
  "private": "true",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,tests}/**/*.{ts,tsx,css,scss,js,jsx,json,md}\"",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "start": "npm run build && node dist/server.js",
    "dev": "nodemon",
    "fetch-airports": "ts-node src/scripts/fetchOpenflightsAirports.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "flight",
    "search",
    "api",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "^4.17.21",
    "@types/jest": "30.0.0",
    "@types/node": "^20.10.6",
    "csv-parse": "6.2.1",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "nodemon": "^3.0.2",
    "prettier": "3.8.4",
    "ts-jest": "29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "8.61.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}