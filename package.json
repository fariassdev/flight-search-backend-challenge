{
  "name": "flight-search-api",
  "version": "1.0.0",
  "description": "Flight search API coding challenge",
  "main": "dist/server.js",
  "private": "true",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,tests}/**/*.{ts,tsx,css,scss,js,jsx,json,md}\"",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "start": "npm run build && node dist/server.js",
    "dev": "nodemon",
    "fetch-airports": "ts-node src/scripts/fetchOpenflightsAirports.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "keywords": [
    "flight",
    "search",
    "api",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "2.8.6",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.21",
    "@types/supertest": "7.2.0",
    "csv-parse": "7.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1"
  },
  "engines": {
    "node": ">=22.23.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,html}": [
      "prettier --write"
    ]
  }
}
